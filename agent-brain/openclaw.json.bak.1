{
    "gateway": {
        "mode": "local",
        "port": 8000
    },
    "skills": {
        "load": {
            "extraDirs": [
                "/workspace/skills"
            ]
        }
    },
    "plugins": {
        "enabled": true,
        "allow": [
            "apa-plugin"
        ]
    },
    "agents": {
        "defaults": {
            "model": {
                "primary": "openrouter/auto"
            },
            "workspace": "/workspace",
            "sandbox": {
                "mode": "off"
            }
        },
        "list": [
            {
                "id": "main",
                "default": true,
                "name": "APA-Brain-Agent",
                "workspace": "/workspace",
                "agentDir": "/workspace/.openclaw/agents/main",
                "model": "openrouter/auto",
                "identity": {
                    "name": "APA-Brain",
                    "theme": "Autonomous Payroll Agent",
                    "emoji": "🤖"
                },
                "tools": {
                    "allow": [
                        "apa_get_rates",
                        "apa_get_batch_details",
                        "apa_send_notification",
                        "apa_manage_wallet",
                        "apa_log_decision",
                        "apa_update_batch",
                        "apa_execute_payout"
                    ]
                },
                "sandbox": {
                    "mode": "off"
                }
            }
        ]
    }
}
