{
  "agents": {
    "defaults": {
      "model": {
        "primary": "openrouter/auto"
      },
      "workspace": "/workspace",
      "compaction": {
        "mode": "safeguard"
      },
      "sandbox": {
        "mode": "off"
      }
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "name": "APA-Brain-Agent",
        "workspace": "/workspace",
        "agentDir": "/workspace/.openclaw/agents/main",
        "model": "openrouter/auto",
        "identity": {
          "name": "APA-Brain",
          "theme": "Autonomous Payroll Agent",
          "emoji": "🤖"
        },
        "sandbox": {
          "mode": "off"
        },
        "tools": {
          "allow": [
            "apa_get_rates",
            "apa_get_batch_details",
            "apa_get_schedule_details",
            "apa_send_notification",
            "apa_manage_wallet",
            "apa_log_decision",
            "apa_update_batch",
            "apa_fiat_transfer",
            "apa_payout",
            "apa_deposit_to_startbutton",
            "apa_get_startbutton_balance"
          ],
          "deny": [
            "bash",
            "browser",
            "canvas",
            "read",
            "write",
            "edit",
            "process"
          ]
        }
      }
    ]
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "gateway": {
    "bind": "lan",
    "port": 8000,
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "45575214285178078e4e65046cc363065ba63e82f19c7028"
    },
    "http": {
      "endpoints": {
        "responses": {
          "enabled": true
        }
      }
    }
  },
  "skills": {
    "load": {
      "extraDirs": [
        "/workspace/skills"
      ]
    }
  },
  "plugins": {
    "enabled": true,
    "allow": [
      "apa-plugin"
    ]
  },
  "meta": {
    "lastTouchedVersion": "2026.3.20",
    "lastTouchedAt": "2026-03-20T14:40:00.000Z"
  }
}
