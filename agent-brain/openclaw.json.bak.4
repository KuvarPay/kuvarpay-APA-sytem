{
    "skills": {
        "load": {
            "extraDirs": [
                "/workspace/skills"
            ]
        }
    },
    "plugins": {
        "load": {
            "paths": [
                "/workspace/plugins"
            ]
        },
        "entries": {
            "apa-plugin": {
                "enabled": true
            }
        }
    },
    "agents": {
        "defaults": {
            "model": {
                "primary": "openrouter/auto"
            }
        },
        "list": [
            {
                "id": "main",
                "name": "APA-Brain",
                "model": "openrouter/auto",
                "tools": {
                    "allow": [
                        "apa_get_rates",
                        "apa_get_batch_details",
                        "apa_send_notification",
                        "apa_manage_wallet",
                        "apa_log_decision",
                        "apa_update_batch",
                        "apa_execute_payout"
                    ]
                },
                "sandbox": {
                    "mode": "off"
                }
            }
        ]
    }
}
