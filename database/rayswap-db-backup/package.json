{
  "name": "rayswap-db",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "clean": "rimraf dist",
    "db:gen": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "dotenv": "^17.2.1",
    "drizzle-orm": "^0.44.4",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/node": "^24.2.0",
    "@types/pg": "^8.15.5",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "tsup": "^8.0.0",
    "rimraf": "^6.0.0",
    "drizzle-orm": "^0.44.4",
    "pg": "^8.16.3",
    "dotenv": "^17.2.1"
  }
}