# APA Backend Configuration
PORT=3001
# Use host.docker.internal to reach your local Postgres/Redis from the container
DATABASE_URL=postgresql://user:pass@host.docker.internal:5432/kuvarpay
REDIS_URL=redis://host.docker.internal:6379

# KuvarPay Core Integration
KUVARPAY_API_KEY=your_core_api_key_here
# OpenClaw service discovery (internal to docker network)
OPENCLAW_URL=http://apa-agent:8000

# WDK Security (CRITICAL)
# This seed phrase must never be committed to Git.
WDK_SEED="your 12 or 24 word master seed phrase here"

# Chains Config
ETH_RPC=https://eth.drpc.org
TRON_RPC=https://api.trongrid.io

# Stellar Network Config
STELLAR_MASTER_WALLET="GA..."
STELLAR_MASTER_SECRET="SA..."
STELLAR_NETWORK=testnet # or public

# Startbutton Gateway Addresses
STARTBUTTON_USDT_DEPOSIT_ADDRESS="0x..."
STARTBUTTON_USDC_DEPOSIT_ADDRESS_STELLAR="GA..."

# AI Provider Keys
# OpenClaw will use these for the agent brain.
ANTHROPIC_API_KEY=your_anthropic_key
OPENAI_API_KEY=your_openai_key
GOOGLE_API_KEY=your_google_key
